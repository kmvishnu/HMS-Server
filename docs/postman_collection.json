            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "oldImageUrl",
                  "value": "data:image/jpeg;base64,...",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/hotels/1/images/replace",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "hotels",
                "1",
