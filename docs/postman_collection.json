{
  "info": {
    "name": "Hotel Booking API",
    "description": "API for Hotel Booking System MVP",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Public Discovery",
      "item": [
        {
          "name": "Get Home Data",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/public/home",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "public",
                "home"
              ]
            }
          }
        },
        {
          "name": "Search Hotels",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/public/hotels?location=New York&checkIn=2024-05-01&checkOut=2024-05-05",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "public",
                "hotels"
              ],
              "query": [
                {
                  "key": "location",
                  "value": "New York"
                },
                {
                  "key": "checkIn",
                  "value": "2024-05-01"
                },
                {
                  "key": "checkOut",
                  "value": "2024-05-05"
                }
              ]
            }
          }
        },
        {
          "name": "Get Public Hotel Details",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/public/hotels/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "public",
                "hotels",
                "1"
              ]
            }
          }
        },
        {
          "name": "Check Availability",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/public/availability?hotelId=1&checkIn=2024-05-01&checkOut=2024-05-05",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "public",
                "availability"
              ],
              "query": [
                {
                  "key": "hotelId",
                  "value": "1"
                },
                {
                  "key": "checkIn",
                  "value": "2024-05-01"
                },
                {
                  "key": "checkOut",
                  "value": "2024-05-05"
                }
              ]
            }
          }
        }
      ]
    },
